// Simako — Kost Management System
// MariaDB · Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUM DEFINITIONS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  PENYEWA // pencari / penyewa kost
  MITRA // owner / pemilik kost
  ADMIN // super admin platform
}

enum KycStatus {
  BELUM_UPLOAD
  MENUNGGU
  DISETUJUI
  DITOLAK
}

enum AssetCategory {
  AVATAR
  KTP
  FOTO_KOST
  FOTO_KAMAR
  BUKTI_BAYAR
  BANNER
  LAINNYA
}

enum RoomStatus {
  TERSEDIA
  TERISI
  MAINTENANCE
}

enum RentalStatus {
  MENUNGGU_BAYAR // booking dibuat, belum transfer
  MENUNGGU_VERIF // sudah upload bukti, menunggu admin cek
  AKTIF // pembayaran terverifikasi, sewa berjalan
  JATUH_TEMPO // sudah melewati tanggal akhir
  SELESAI // penyewa sudah keluar
  DIBATALKAN
}

enum TransactionType {
  BOOKING // pembayaran sewa pertama
  PERPANJANGAN // perpanjangan sewa bulanan
  DENDA
  REFUND
}

enum TransactionStatus {
  MENUNGGU_BUKTI
  MENUNGGU_VERIF
  LUNAS
  DITOLAK
  DIBATALKAN
}

enum ComplaintStatus {
  TERBUKA
  DIPROSES
  SELESAI
  DITUTUP
}

enum ComplaintPriority {
  RENDAH
  SEDANG
  TINGGI
  KRITIS
}

enum BannerPlacement {
  HERO
  SIDEBAR
  TENGAH
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  SUSPEND
}

// ─────────────────────────────────────────────────────────────────────────────
// 1. ROLES
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          Int      @id @default(autoincrement())
  name        UserRole @unique
  label       String   @db.VarChar(50)
  description String?  @db.VarChar(255)

  users User[]

  @@map("roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// 2. USERS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Char(36)
  roleId       Int
  email        String    @unique @db.VarChar(191)
  passwordHash String    @db.VarChar(255)
  isVerified   Boolean   @default(false)
  isSuspended  Boolean   @default(false)
  suspendedAt  DateTime?
  suspendNote  String?   @db.VarChar(500)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  role             Role            @relation(fields: [roleId], references: [id])
  profile          UserProfile?
  ownerProfile     OwnerProfile?
  settings         UserSettings?
  sessions         ActiveSession[]
  otpTokens        OtpToken[]
  boardingHouses   BoardingHouse[]
  rentals          Rental[]
  wishlists        Wishlist[]
  chatRoomsAsBuyer ChatRoom[]      @relation(name: "ChatRoomBuyer")
  chatMessages     ChatMessage[]
  broadcasts       Broadcast[]
  complaints       Complaint[]
  reviews          Review[]
  articles         Article[]
  auditLogs        AuditLog[]

  // asset relations (named to avoid ambiguity)
  avatarAsset   Asset?  @relation(name: "UserAvatar", fields: [avatarAssetId], references: [id])
  avatarAssetId String? @unique @db.Char(36)

  @@index([roleId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// 3. USER_PROFILES
// ─────────────────────────────────────────────────────────────────────────────

model UserProfile {
  id           String    @id @default(uuid()) @db.Char(36)
  userId       String    @unique @db.Char(36)
  namaLengkap  String    @db.VarChar(191)
  telepon      String?   @db.VarChar(20)
  alamat       String?   @db.Text
  tanggalLahir DateTime?
  jenisKelamin String?   @db.VarChar(20)
  kampusId     Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kampus MasterCampus? @relation(fields: [kampusId], references: [id])

  @@index([kampusId])
  @@map("user_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// 4. OWNER_PROFILES
// ─────────────────────────────────────────────────────────────────────────────

model OwnerProfile {
  id            String    @id @default(uuid()) @db.Char(36)
  userId        String    @unique @db.Char(36)
  namaUsaha     String?   @db.VarChar(191)
  namaBank      String?   @db.VarChar(100)
  rekeningNo    String?   @db.VarChar(50)
  rekeningNama  String?   @db.VarChar(191)
  kycStatus     KycStatus @default(BELUM_UPLOAD)
  kycNote       String?   @db.VarChar(500)
  kycVerifiedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ktpAsset   Asset?  @relation(name: "OwnerKtp", fields: [ktpAssetId], references: [id])
  ktpAssetId String? @unique @db.Char(36)

  @@map("owner_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// 5. USER_SETTINGS
// ─────────────────────────────────────────────────────────────────────────────

model UserSettings {
  id              String  @id @default(uuid()) @db.Char(36)
  userId          String  @unique @db.Char(36)
  notifEmail      Boolean @default(true)
  notifWhatsapp   Boolean @default(false)
  notifPembayaran Boolean @default(true)
  notifBroadcast  Boolean @default(true)
  bahasa          String  @default("id") @db.VarChar(10)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// 6. ACTIVE_SESSIONS
// ─────────────────────────────────────────────────────────────────────────────

model ActiveSession {
  id           String   @id @default(uuid()) @db.Char(36)
  userId       String   @db.Char(36)
  tokenHash    String   @unique @db.VarChar(255)
  ipAddress    String?  @db.VarChar(45)
  userAgent    String?  @db.VarChar(512)
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("active_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// 7. ASSETS (file storage metadata)
// ─────────────────────────────────────────────────────────────────────────────

model Asset {
  id           String        @id @default(uuid()) @db.Char(36)
  category     AssetCategory
  originalName String        @db.VarChar(255)
  storagePath  String        @db.VarChar(512)
  mimeType     String        @db.VarChar(100)
  sizeBytes    Int
  url          String        @db.VarChar(512)
  uploadedBy   String?       @db.Char(36)
  createdAt    DateTime      @default(now())

  // Named reverse relations to avoid Prisma ambiguity
  userAvatars         User[]               @relation(name: "UserAvatar")
  ownerKtps           OwnerProfile[]       @relation(name: "OwnerKtp")
  boardingHouseImages BoardingHouseImage[] @relation(name: "BoardingHouseImageAsset")
  roomImages          RoomImage[]          @relation(name: "RoomImageAsset")
  transactionProofs   Transaction[]        @relation(name: "TransactionProof")
  banners             CmsBanner[]          @relation(name: "BannerImage")
  articleCovers       Article[]            @relation(name: "ArticleCover")

  @@index([category])
  @@map("assets")
}

// ─────────────────────────────────────────────────────────────────────────────
// 8. MASTER_CAMPUSES
// ─────────────────────────────────────────────────────────────────────────────

model MasterCampus {
  id        Int      @id @default(autoincrement())
  nama      String   @db.VarChar(191)
  singkatan String   @db.VarChar(20)
  kota      String   @db.VarChar(100)
  alamat    String?  @db.Text
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  isActive  Boolean  @default(true)

  userProfiles   UserProfile[]
  boardingHouses BoardingHouse[]

  @@map("master_campuses")
}

// ─────────────────────────────────────────────────────────────────────────────
// 9. MASTER_BANKS
// ─────────────────────────────────────────────────────────────────────────────

model MasterBank {
  id       Int     @id @default(autoincrement())
  nama     String  @db.VarChar(100)
  kode     String  @unique @db.VarChar(10)
  isActive Boolean @default(true)

  @@map("master_banks")
}

// ─────────────────────────────────────────────────────────────────────────────
// 10. MASTER_FACILITIES
// ─────────────────────────────────────────────────────────────────────────────

model MasterFacility {
  id       Int     @id @default(autoincrement())
  nama     String  @db.VarChar(100)
  icon     String? @db.VarChar(50)
  kategori String  @db.VarChar(50)
  isActive Boolean @default(true)

  boardingHouseFacilities BoardingHouseFacility[]
  roomFacilities          RoomFacility[]

  @@map("master_facilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// 11. BOARDING_HOUSES
// ─────────────────────────────────────────────────────────────────────────────

model BoardingHouse {
  id           String   @id @default(uuid()) @db.Char(36)
  ownerId      String   @db.Char(36)
  kampusId     Int?
  nama         String   @db.VarChar(191)
  slug         String   @unique @db.VarChar(220)
  deskripsi    String?  @db.Text
  alamat       String   @db.Text
  kota         String   @db.VarChar(100)
  kodePos      String?  @db.VarChar(10)
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  jenisKelamin String   @db.VarChar(20)
  isVerified   Boolean  @default(false)
  isPublished  Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner      User                    @relation(fields: [ownerId], references: [id])
  kampus     MasterCampus?           @relation(fields: [kampusId], references: [id])
  facilities BoardingHouseFacility[]
  images     BoardingHouseImage[]
  rooms      Room[]
  wishlists  Wishlist[]
  chatRooms  ChatRoom[]
  complaints Complaint[]
  reviews    Review[]

  @@index([ownerId])
  @@index([kampusId])
  @@index([slug])
  @@map("boarding_houses")
}

// ─────────────────────────────────────────────────────────────────────────────
// 12. BOARDING_HOUSE_FACILITIES (M-to-N pivot)
// ─────────────────────────────────────────────────────────────────────────────

model BoardingHouseFacility {
  boardingHouseId String @db.Char(36)
  facilityId      Int

  boardingHouse BoardingHouse  @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)
  facility      MasterFacility @relation(fields: [facilityId], references: [id])

  @@id([boardingHouseId, facilityId])
  @@map("boarding_house_facilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// 13. BOARDING_HOUSE_IMAGES
// ─────────────────────────────────────────────────────────────────────────────

model BoardingHouseImage {
  id              String  @id @default(uuid()) @db.Char(36)
  boardingHouseId String  @db.Char(36)
  assetId         String  @db.Char(36)
  urutan          Int     @default(0)
  isCover         Boolean @default(false)
  caption         String? @db.VarChar(255)

  boardingHouse BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)
  asset         Asset         @relation(name: "BoardingHouseImageAsset", fields: [assetId], references: [id])

  @@index([boardingHouseId])
  @@map("boarding_house_images")
}

// ─────────────────────────────────────────────────────────────────────────────
// 14. ROOMS
// ─────────────────────────────────────────────────────────────────────────────

model Room {
  id              String     @id @default(uuid()) @db.Char(36)
  boardingHouseId String     @db.Char(36)
  nomorKamar      String     @db.VarChar(20)
  lantai          Int?
  luasM2          Decimal?   @db.Decimal(5, 2)
  hargaBulan      Int
  hargaTahun      Int?
  kapasitas       Int        @default(1)
  status          RoomStatus @default(TERSEDIA)
  deskripsi       String?    @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  boardingHouse BoardingHouse  @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)
  facilities    RoomFacility[]
  images        RoomImage[]
  rentals       Rental[]

  @@unique([boardingHouseId, nomorKamar])
  @@index([boardingHouseId])
  @@map("rooms")
}

// ─────────────────────────────────────────────────────────────────────────────
// 15. ROOM_FACILITIES (M-to-N pivot)
// ─────────────────────────────────────────────────────────────────────────────

model RoomFacility {
  roomId     String @db.Char(36)
  facilityId Int

  room     Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  facility MasterFacility @relation(fields: [facilityId], references: [id])

  @@id([roomId, facilityId])
  @@map("room_facilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// 16. ROOM_IMAGES
// ─────────────────────────────────────────────────────────────────────────────

model RoomImage {
  id      String  @id @default(uuid()) @db.Char(36)
  roomId  String  @db.Char(36)
  assetId String  @db.Char(36)
  urutan  Int     @default(0)
  isCover Boolean @default(false)

  room  Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  asset Asset @relation(name: "RoomImageAsset", fields: [assetId], references: [id])

  @@index([roomId])
  @@map("room_images")
}

// ─────────────────────────────────────────────────────────────────────────────
// 17. RENTALS
// ─────────────────────────────────────────────────────────────────────────────

model Rental {
  id             String       @id @default(uuid()) @db.Char(36)
  roomId         String       @db.Char(36)
  penyewaId      String       @db.Char(36)
  tanggalMulai   DateTime     @db.Date
  tanggalAkhir   DateTime     @db.Date
  hargaDisetujui Int
  status         RentalStatus @default(MENUNGGU_BAYAR)
  catatan        String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  room         Room          @relation(fields: [roomId], references: [id])
  penyewa      User          @relation(fields: [penyewaId], references: [id])
  transactions Transaction[]

  @@index([roomId])
  @@index([penyewaId])
  @@index([status])
  @@map("rentals")
}

// ─────────────────────────────────────────────────────────────────────────────
// 18. TRANSACTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id             String            @id @default(uuid()) @db.Char(36)
  rentalId       String            @db.Char(36)
  tipe           TransactionType
  nominal        Int
  periodeAwal    DateTime?         @db.Date
  periodeAkhir   DateTime?         @db.Date
  batasTransfer  DateTime?
  buktiAssetId   String?           @db.Char(36)
  nomorReferensi String?           @db.VarChar(100)
  namaBank       String?           @db.VarChar(100)
  status         TransactionStatus @default(MENUNGGU_BUKTI)
  verifiedById   String?           @db.Char(36)
  verifiedAt     DateTime?
  rejectionNote  String?           @db.VarChar(500)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  rental     Rental @relation(fields: [rentalId], references: [id])
  buktiAsset Asset? @relation(name: "TransactionProof", fields: [buktiAssetId], references: [id])

  @@index([rentalId])
  @@index([status])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// 19. WISHLISTS
// ─────────────────────────────────────────────────────────────────────────────

model Wishlist {
  userId          String   @db.Char(36)
  boardingHouseId String   @db.Char(36)
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardingHouse BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)

  @@id([userId, boardingHouseId])
  @@map("wishlists")
}

// ─────────────────────────────────────────────────────────────────────────────
// 20. CHAT_ROOMS
// ─────────────────────────────────────────────────────────────────────────────

model ChatRoom {
  id              String   @id @default(uuid()) @db.Char(36)
  boardingHouseId String   @db.Char(36)
  buyerId         String   @db.Char(36)
  createdAt       DateTime @default(now())
  lastMessageAt   DateTime @default(now())

  boardingHouse BoardingHouse @relation(fields: [boardingHouseId], references: [id])
  buyer         User          @relation(name: "ChatRoomBuyer", fields: [buyerId], references: [id])
  messages      ChatMessage[]

  @@unique([boardingHouseId, buyerId])
  @@index([buyerId])
  @@map("chat_rooms")
}

// ─────────────────────────────────────────────────────────────────────────────
// 21. CHAT_MESSAGES
// ─────────────────────────────────────────────────────────────────────────────

model ChatMessage {
  id         String   @id @default(uuid()) @db.Char(36)
  chatRoomId String   @db.Char(36)
  senderId   String   @db.Char(36)
  konten     String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id])

  @@index([chatRoomId])
  @@index([senderId])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// 22. BROADCASTS
// ─────────────────────────────────────────────────────────────────────────────

model Broadcast {
  id              String    @id @default(uuid()) @db.Char(36)
  senderId        String    @db.Char(36)
  judul           String    @db.VarChar(255)
  konten          String    @db.Text
  targetRole      UserRole?
  boardingHouseId String?   @db.Char(36)
  createdAt       DateTime  @default(now())

  sender User @relation(fields: [senderId], references: [id])

  @@index([senderId])
  @@map("broadcasts")
}

// ─────────────────────────────────────────────────────────────────────────────
// 23. COMPLAINTS
// ─────────────────────────────────────────────────────────────────────────────

model Complaint {
  id              String            @id @default(uuid()) @db.Char(36)
  pelaporId       String            @db.Char(36)
  boardingHouseId String?           @db.Char(36)
  judul           String            @db.VarChar(255)
  deskripsi       String            @db.Text
  kategori        String            @db.VarChar(100)
  prioritas       ComplaintPriority @default(SEDANG)
  status          ComplaintStatus   @default(TERBUKA)
  resolusi        String?           @db.Text
  resolvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  pelapor       User           @relation(fields: [pelaporId], references: [id])
  boardingHouse BoardingHouse? @relation(fields: [boardingHouseId], references: [id])

  @@index([pelaporId])
  @@index([status])
  @@map("complaints")
}

// ─────────────────────────────────────────────────────────────────────────────
// 24. FAQS
// ─────────────────────────────────────────────────────────────────────────────

model Faq {
  id         Int      @id @default(autoincrement())
  pertanyaan String   @db.VarChar(500)
  jawaban    String   @db.Text
  kategori   String   @db.VarChar(100)
  urutan     Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("faqs")
}

// ─────────────────────────────────────────────────────────────────────────────
// 25. CMS_BANNERS
// ─────────────────────────────────────────────────────────────────────────────

model CmsBanner {
  id           Int             @id @default(autoincrement())
  judul        String          @db.VarChar(191)
  deskripsi    String?         @db.VarChar(500)
  imageAssetId String          @db.Char(36)
  linkUrl      String?         @db.VarChar(512)
  placement    BannerPlacement @default(HERO)
  urutan       Int             @default(0)
  isActive     Boolean         @default(true)
  mulaiAt      DateTime?
  berakhirAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  imageAsset Asset @relation(name: "BannerImage", fields: [imageAssetId], references: [id])

  @@map("cms_banners")
}

// ─────────────────────────────────────────────────────────────────────────────
// 26. OTP_TOKENS
// ─────────────────────────────────────────────────────────────────────────────

model OtpToken {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @db.Char(36)
  tujuan    String   @db.VarChar(50)
  kodeHash  String   @db.VarChar(255)
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("otp_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// 27. REVIEWS (ulasan & rating)
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id              String   @id @default(uuid()) @db.Char(36)
  boardingHouseId String   @db.Char(36)
  reviewerId      String   @db.Char(36)
  rentalId        String?  @db.Char(36)
  rating          Int // 1–5
  komentar        String?  @db.Text
  isApproved      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  boardingHouse BoardingHouse @relation(fields: [boardingHouseId], references: [id], onDelete: Cascade)
  reviewer      User          @relation(fields: [reviewerId], references: [id])

  @@index([boardingHouseId])
  @@index([reviewerId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// 28. ARTICLES (blog)
// ─────────────────────────────────────────────────────────────────────────────

model Article {
  id           String    @id @default(uuid()) @db.Char(36)
  authorId     String?   @db.Char(36)
  judul        String    @db.VarChar(255)
  slug         String    @unique @db.VarChar(280)
  ringkasan    String?   @db.VarChar(500)
  konten       String    @db.LongText
  kategori     String    @db.VarChar(100)
  coverAssetId String?   @db.Char(36)
  isPublished  Boolean   @default(false)
  publishedAt  DateTime?
  viewCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author     User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  coverAsset Asset? @relation(name: "ArticleCover", fields: [coverAssetId], references: [id])

  @@index([slug])
  @@index([kategori])
  @@map("articles")
}

// ─────────────────────────────────────────────────────────────────────────────
// 29. AUDIT_LOGS
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id            String      @id @default(uuid()) @db.Char(36)
  userId        String?     @db.Char(36)
  action        AuditAction
  targetModel   String      @db.VarChar(100)
  targetId      String?     @db.VarChar(36)
  perubahanLama Json?
  perubahanBaru Json?
  ipAddress     String?     @db.VarChar(45)
  userAgent     String?     @db.VarChar(512)
  createdAt     DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([targetModel, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}
