# Database
DATABASE_URL="mysql://user:password@localhost:3306/simako"

# Application
APP_URL="http://localhost:3000"
APP_SECRET="ganti-dengan-secret-acak-minimal-32-karakter"
NODE_ENV="development"

# Session
SESSION_TTL_SECONDS=86400

# OTP
OTP_TTL_SECONDS=300

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="no-reply@simako.id"
SMTP_PASS="smtp-password"
SMTP_FROM="SIMAKO <no-reply@simako.id>"

# Upload
UPLOAD_MAX_MB=5

# Public (exposed to client via VITE_)
VITE_APP_NAME="Simako"
VITE_APP_URL="http://localhost:3000"
